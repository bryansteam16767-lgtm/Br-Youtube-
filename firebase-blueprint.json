{
  "entities": {
    "User": {
      "title": "User",
      "description": "Sensitive user information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "Channel": {
      "title": "Channel",
      "description": "Public channel information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "bannerURL": { "type": "string" },
        "bio": { "type": "string" },
        "subscriberCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "Video": {
      "title": "Video",
      "description": "Video metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "thumbnailUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "views": { "type": "integer" },
        "likes": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "tags": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["id", "title", "videoUrl", "authorId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on a video",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "videoId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "videoId", "authorId", "text", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "User subscription to a creator",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subscriberId": { "type": "string" },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "subscriberId", "creatorId", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "Alert for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["new_video", "live_stream"] },
        "message": { "type": "string" },
        "videoId": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "message", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Sensitive user profiles"
    },
    "/channels/{userId}": {
      "schema": "Channel",
      "description": "Public channel profiles"
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Video content"
    },
    "/videos/{videoId}/comments/{commentId}": {
      "schema": "Comment",
      "description": "Comments on videos"
    },
    "/subscriptions/{subId}": {
      "schema": "Subscription",
      "description": "User subscriptions"
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
